{
  "name": "markdown-wysiwyg",
  "displayName": "Markdown WYSIWYG",
  "description": "Markdownをその場で直接WYSIWYG編集できるカスタムエディタ",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "publisher": "jimpei",
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "typora"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:markdownWysiwyg.editor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdownWysiwyg.editor",
        "displayName": "Markdown WYSIWYG",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "markdownWysiwyg.openWithWysiwyg",
        "title": "Markdown WYSIWYGで開く",
        "category": "Markdown WYSIWYG"
      },
      {
        "command": "markdownWysiwyg.toggleWysiwyg",
        "title": "Markdown WYSIWYGとテキスト表示を切り替え",
        "category": "Markdown WYSIWYG"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@milkdown/core": "^7.5.0",
    "@milkdown/plugin-history": "^7.5.0",
    "@milkdown/plugin-listener": "^7.5.0",
    "@milkdown/plugin-prism": "^7.21.3",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/theme-nord": "^7.5.0"
  }
}
